generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  name         String?
  email        String     @unique
  passwordHash String
  image        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  locations    Location[]

  @@map("users")
}

model Location {
  id        String   @id @default(cuid())
  latitude  Float
  longitude Float
  name      String
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos    Photo[]

  @@index([userId])
  @@index([latitude, longitude])
  @@map("locations")
}

model Photo {
  id           String   @id @default(cuid())
  url          String
  thumbnailUrl String?
  title        String?
  description  String?
  takenAt      DateTime?
  createdAt    DateTime @default(now())
  locationId   String
  location     Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId])
  @@map("photos")
}
