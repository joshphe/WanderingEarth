# 数据库 - Neon PostgreSQL
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# NextAuth
AUTH_SECRET="your-auth-secret"
# AUTH_URL 仅在本地开发时指向 localhost；部署到 Vercel 后设为实际域名
AUTH_URL="http://localhost:3000"
# AUTH_TRUST_HOST 部署到非 Vercel 平台时需设为 true（Vercel 自动检测）
# AUTH_TRUST_HOST="true"
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# 七牛云 Kodo 对象存储
# 获取 AK/SK: https://portal.qiniu.com/user/key
QINIU_ACCESS_KEY=""
QINIU_SECRET_KEY=""
QINIU_BUCKET="wandering-earth"
# 测试域名（30天有效），备案后可换为自定义加速域名如 https://cdn.echova.top
QINIU_DOMAIN="https://your-test-domain.bkt.clouddn.com"
# QINIU_UPLOAD_URL 可选，默认华东 https://upload.qiniup.com

# 应用配置
NEXT_PUBLIC_APP_URL="http://localhost:3000"
